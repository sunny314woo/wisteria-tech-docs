<script>
(() => {
  const languageStorageKey = 'wisteria-ui-language';
  const themeStorageKey = 'wisteria-ui-theme';
  const dictionary = {
    'zh-CN': {
      subtitle: 'AI 对话整理、导出与本地知识管理',
      siteDescription: 'Wisteria Software 的 AI 对话工作流博客，分享 ChatGPT、Gemini、Outline、Inbox、本地优先归档与隐私友好的知识管理实践。',
      nav: {
        home: '首页',
        categories: '分类',
        tags: '标签',
        archives: '归档',
        about: '关于',
        search: '搜索'
      },
      sidebar: {
        toc: '文章目录',
        overview: '站点概览',
        posts: '日志',
        categories: '分类',
        tags: '标签',
        recent: '近期文章'
      },
      post: {
        posted: '发表于',
        edited: '更新于',
        in: '分类于'
      },
      search: {
        placeholder: '搜索...',
        empty: '没有找到任何搜索结果：${query}',
        hits_time: '找到 ${hits} 个搜索结果（用时 ${time} 毫秒）',
        hits: '找到 ${hits} 个搜索结果'
      },
      accessibility: {
        navToggle: '切换导航栏',
        search: '搜索',
        backToTop: '返回顶部',
        language: '语言',
        theme: '切换明暗模式'
      },
      officialSite: '官网',
      topbarSubtitle: 'AI 对话工作流',
      searchButton: '搜索',
      theme: '主题'
    },
    en: {
      subtitle: 'AI conversation workflows, export, and local knowledge management',
      siteDescription: 'Wisteria Software blog for AI conversation workflows, ChatGPT, Gemini, Outline, Inbox, local-first archiving, and privacy-friendly knowledge management.',
      nav: {
        home: 'Home',
        categories: 'Categories',
        tags: 'Tags',
        archives: 'Archives',
        about: 'About',
        search: 'Search'
      },
      sidebar: {
        toc: 'Table of Contents',
        overview: 'Overview',
        posts: 'Posts',
        categories: 'Categories',
        tags: 'Tags',
        recent: 'Recent Posts'
      },
      post: {
        posted: 'Posted on',
        edited: 'Updated on',
        in: 'In'
      },
      search: {
        placeholder: 'Search...',
        empty: 'No results found for: ${query}',
        hits_time: '${hits} results found in ${time} ms',
        hits: '${hits} results found'
      },
      accessibility: {
        navToggle: 'Toggle navigation',
        search: 'Search',
        backToTop: 'Back to top',
        language: 'Language',
        theme: 'Toggle color theme'
      },
      officialSite: 'Official',
      topbarSubtitle: 'AI conversation workflows',
      searchButton: 'Search',
      theme: 'Theme'
    }
  };

  const normalize = language => String(language || '').toLowerCase().startsWith('zh') ? 'zh-CN' : 'en';
  const getInitialLanguage = () => {
    const saved = localStorage.getItem(languageStorageKey);
    if (saved && dictionary[saved]) return saved;
    return normalize(navigator.language || (navigator.languages && navigator.languages[0]) || 'zh-CN');
  };

  const getInitialTheme = () => {
    const saved = localStorage.getItem(themeStorageKey);
    if (saved === 'light' || saved === 'dark') return saved;
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  };

  const textOnly = (element, value) => {
    if (!element) return;
    const icon = element.querySelector('i');
    element.textContent = '';
    if (icon) element.appendChild(icon);
    element.append(value);
  };

  const replaceTextNodes = (root, replacements) => {
    if (!root) return;
    const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
    const nodes = [];
    while (walker.nextNode()) nodes.push(walker.currentNode);
    nodes.forEach(node => {
      const value = node.nodeValue.trim();
      if (replacements[value]) node.nodeValue = node.nodeValue.replace(value, replacements[value]);
    });
  };

  const applyLanguage = language => {
    const lang = dictionary[language] ? language : 'zh-CN';
    const t = dictionary[lang];
    document.documentElement.lang = lang;
    document.documentElement.dataset.uiLang = lang;
    localStorage.setItem(languageStorageKey, lang);

    const subtitle = document.querySelector('.site-subtitle');
    if (subtitle) subtitle.textContent = t.subtitle;

    const siteDescription = document.querySelector('.site-description');
    if (siteDescription) siteDescription.textContent = t.siteDescription;

    const menuMap = {
      '.menu-item-home > a': t.nav.home,
      '.menu-item-categories > a': t.nav.categories,
      '.menu-item-tags > a': t.nav.tags,
      '.menu-item-archives > a': t.nav.archives,
      '.menu-item-about > a': t.nav.about,
      '.menu-item-search > a': t.nav.search
    };
    Object.entries(menuMap).forEach(([selector, label]) => textOnly(document.querySelector(selector), label));

    const toc = document.querySelector('.sidebar-nav-toc');
    if (toc) toc.textContent = t.sidebar.toc;
    const overview = document.querySelector('.sidebar-nav-overview');
    if (overview) overview.textContent = t.sidebar.overview;

    const stateLabels = document.querySelectorAll('.site-state-item-name');
    if (stateLabels[0]) stateLabels[0].textContent = t.sidebar.posts;
    if (stateLabels[1]) stateLabels[1].textContent = t.sidebar.categories;
    if (stateLabels[2]) stateLabels[2].textContent = t.sidebar.tags;

    document.querySelectorAll('[data-i18n="recent_posts"], .links-of-blogroll-title').forEach(element => {
      element.textContent = t.sidebar.recent;
    });
    document.querySelectorAll('[data-i18n="official_site"]').forEach(element => {
      element.textContent = t.officialSite;
    });
    document.querySelectorAll('[data-i18n-title="official_site"]').forEach(element => {
      element.setAttribute('aria-label', t.officialSite);
      element.setAttribute('title', t.officialSite);
    });
    document.querySelectorAll('[data-i18n="topbar_subtitle"]').forEach(element => {
      element.textContent = t.topbarSubtitle;
    });
    document.querySelectorAll('[data-i18n="search_button"]').forEach(element => {
      element.textContent = t.searchButton;
    });
    document.querySelectorAll('[data-i18n="nav_home"]').forEach(element => {
      element.textContent = t.nav.home;
    });
    document.querySelectorAll('[data-i18n="nav_categories"]').forEach(element => {
      element.textContent = t.nav.categories;
    });
    document.querySelectorAll('[data-i18n="nav_tags"]').forEach(element => {
      element.textContent = t.nav.tags;
    });
    document.querySelectorAll('[data-i18n="nav_archives"]').forEach(element => {
      element.textContent = t.nav.archives;
    });
    document.querySelectorAll('[data-i18n="nav_about"]').forEach(element => {
      element.textContent = t.nav.about;
    });
    document.querySelectorAll('[data-i18n="theme"]').forEach(element => {
      element.textContent = t.theme;
    });

    document.querySelectorAll('.post-meta').forEach(meta => replaceTextNodes(meta, {
      '发表于': t.post.posted,
      'Posted on': t.post.posted,
      '更新于': t.post.edited,
      'Updated on': t.post.edited,
      '分类于': t.post.in,
      'In': t.post.in
    }));

    document.querySelectorAll('.search-input').forEach(input => {
      input.setAttribute('placeholder', t.search.placeholder);
    });

    if (window.CONFIG) {
      window.CONFIG.i18n = {
        placeholder: t.search.placeholder,
        empty: t.search.empty,
        hits_time: t.search.hits_time,
        hits: t.search.hits
      };
    }

    document.querySelectorAll('.site-nav-toggle .toggle').forEach(element => {
      element.setAttribute('aria-label', t.accessibility.navToggle);
    });
    document.querySelectorAll('.popup-trigger').forEach(element => {
      element.setAttribute('aria-label', t.accessibility.search);
    });
    document.querySelectorAll('.back-to-top').forEach(element => {
      element.setAttribute('aria-label', t.accessibility.backToTop);
    });
    document.querySelectorAll('.ui-language-switch').forEach(element => {
      element.setAttribute('aria-label', t.accessibility.language);
    });
    document.querySelectorAll('[data-ui-theme-toggle]').forEach(element => {
      element.setAttribute('aria-label', t.accessibility.theme);
      element.setAttribute('title', t.accessibility.theme);
    });
    document.querySelectorAll('[data-ui-lang-option]').forEach(button => {
      const active = button.dataset.uiLangOption === lang;
      button.classList.toggle('is-active', active);
      button.setAttribute('aria-pressed', String(active));
    });
    document.querySelectorAll('[data-ui-lang-label]').forEach(element => {
      element.textContent = lang === 'zh-CN' ? '中' : 'EN';
    });
    document.querySelectorAll('[data-ui-lang-toggle]').forEach(button => {
      button.dataset.currentLang = lang;
      button.setAttribute('aria-label', t.accessibility.language);
      button.setAttribute('title', t.accessibility.language);
    });
  };

  const applyTheme = theme => {
    const nextTheme = theme === 'dark' ? 'dark' : 'light';
    document.documentElement.dataset.theme = nextTheme;
    localStorage.setItem(themeStorageKey, nextTheme);
    document.querySelectorAll('[data-ui-theme-toggle]').forEach(button => {
      button.dataset.theme = nextTheme;
      button.setAttribute('aria-pressed', String(nextTheme === 'dark'));
    });
  };

  const toggleTheme = () => {
    const current = document.documentElement.dataset.theme || getInitialTheme();
    applyTheme(current === 'dark' ? 'light' : 'dark');
  };

  document.addEventListener('click', event => {
    const languageButton = event.target.closest('[data-ui-lang-option]');
    if (languageButton) {
      applyLanguage(languageButton.dataset.uiLangOption);
      return;
    }
    const languageToggle = event.target.closest('[data-ui-lang-toggle]');
    if (languageToggle) {
      const current = document.documentElement.dataset.uiLang || getInitialLanguage();
      applyLanguage(current === 'zh-CN' ? 'en' : 'zh-CN');
      return;
    }
    if (event.target.closest('[data-ui-theme-toggle]')) {
      toggleTheme();
    }
  });

  document.addEventListener('keydown', event => {
    const isSearchShortcut = (event.key || '').toLowerCase() === 'k' && (event.metaKey || event.ctrlKey);
    if (!isSearchShortcut) return;
    event.preventDefault();
    document.querySelector('.wt-search-trigger.popup-trigger')?.click();
  });

  const updateSearchShortcut = () => {
    const shortcut = /mac|iphone|ipad|ipod/i.test(navigator.platform || '') ? '⌘ K' : 'Ctrl K';
    document.querySelectorAll('.wt-search-trigger kbd').forEach(element => {
      element.textContent = shortcut;
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      updateSearchShortcut();
      applyTheme(getInitialTheme());
      applyLanguage(getInitialLanguage());
    });
  } else {
    updateSearchShortcut();
    applyTheme(getInitialTheme());
    applyLanguage(getInitialLanguage());
  }
})();
</script>
