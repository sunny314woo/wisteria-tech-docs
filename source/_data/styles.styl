/* ================================================================
   Wisteria Tech Docs — Docs-style Brand (Tailwind / Vercel inspired)
   NexT Pisces theme override
   ================================================================ */

// ----------------------------------------------------------
// Colors — classic blue
// ----------------------------------------------------------
$brand-primary       = #2563eb
$brand-primary-soft  = #dbeafe
$brand-primary-light = #eff6ff
$brand-text          = #111827
$brand-muted         = #6b7280
$brand-border        = #e5e7eb
$brand-bg            = #ffffff
$brand-page-bg       = #ffffff
$brand-code-bg       = #eff6ff
$brand-radius        = 6px
$brand-radius-sm     = 4px

// ----------------------------------------------------------
// 1. Global
// ----------------------------------------------------------
body {
  background: $brand-page-bg;
  color: $brand-text;
  font-family: -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

// ----------------------------------------------------------
// 2. Site branding — dark header like Tailwind docs
// ----------------------------------------------------------
.site-brand-container {
  background: #0f172a;
  padding: 24px 20px 20px 20px;
}

.site-title {
  font-weight: 700;
  font-size: 1.1rem;
  letter-spacing: -0.01em;
}

.site-title a,
.site-title a:hover {
  color: #ffffff;
}

.site-subtitle {
  color: #94a3b8;
  margin-top: 4px;
  font-size: 0.75rem;
  font-weight: 400;
  line-height: 1.5;
}

// ----------------------------------------------------------
// 3. Menu — clean nav links, dark bg
// ----------------------------------------------------------
.site-nav {
  border-top: 1px solid #1e293b;
  padding-top: 12px;
  margin-top: 16px;
}

.site-nav .menu-item {
  margin: 1px 0;
}

.site-nav .menu-item a {
  color: #94a3b8;
  font-weight: 500;
  font-size: 0.875rem;
  padding: 6px 12px;
  border-radius: $brand-radius-sm;
  transition: all 150ms ease;
  display: block;
}

.site-nav .menu-item a:hover {
  color: #ffffff;
  background: #1e293b;
}

.site-nav .menu-item-active a {
  color: #ffffff;
  background: $brand-primary;
  border-left: none;
  font-weight: 600;
}

.menu-item .badge {
  background: rgba(255,255,255,0.15);
  color: #cbd5e1;
  font-weight: 500;
}

// ----------------------------------------------------------
// 4. Sidebar — flat, clean, no shadows
// ----------------------------------------------------------
.sidebar-inner {
  background: $brand-bg;
  border-radius: 0;
  box-shadow: none;
  border: none;
  border-right: 1px solid $brand-border;
  padding: 0;
  overflow: visible;
}

.sidebar {
  background: transparent;
}

// ----------------------------------------------------------
// 5. Sidebar panels — docs-nav style
// ----------------------------------------------------------
.sidebar-panel {
  padding: 0 20px 20px 20px;
}

.links-of-blogroll {
  margin-top: 20px;
  padding-top: 16px;
  border-top: 1px solid $brand-border;
}

.links-of-blogroll-title {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: $brand-muted;
  margin: 0 0 8px 0;
  padding: 0;
}

.links-of-blogroll-list {
  list-style: none;
  margin: 0;
  padding: 0;
}

.links-of-blogroll-item {
  margin: 0;
  padding: 0;
}

.links-of-blogroll-item a {
  display: block;
  color: #475569;
  font-size: 0.825rem;
  padding: 4px 8px;
  border-radius: $brand-radius-sm;
  transition: all 120ms ease;
  line-height: 1.4;
  white-space: normal;
  overflow: visible;
  border-left: 2px solid transparent;
}

.links-of-blogroll-item a:hover {
  color: $brand-primary;
  background: $brand-primary-light;
  border-left-color: $brand-primary;
}

// Sidebar state (posts/categories/tags count)
.site-state {
  padding: 4px 0;
}

.site-state-item {
  padding: 0 8px;
}

.site-state-item a {
  color: #475569;
  font-size: 0.8rem;
  border-bottom: none;
}

.site-state-item a:hover {
  color: $brand-primary;
}

.site-state-item-count {
  font-weight: 700;
  font-size: 1rem;
  color: $brand-text;
}

// ----------------------------------------------------------
// 6. Post list — clean, no card, subtle separators
// ----------------------------------------------------------
.post-block {
  background: transparent;
  border-radius: 0;
  box-shadow: none;
  border: none;
  border-bottom: 1px solid $brand-border;
  margin-bottom: 0;
  padding: 28px 0;
  transition: none;
  text-align: left;
}

.post-block:hover {
  transform: none;
  box-shadow: none;
}

.post-block:first-child {
  padding-top: 8px;
}

.post-block + .post-block {
  margin-top: 0;
}

// Post titles
.post-title {
  font-size: 1.2rem;
  font-weight: 600;
  line-height: 1.4;
  letter-spacing: -0.01em;
  text-align: left;
  margin-bottom: 6px;
}

.post-title a {
  color: $brand-text;
  transition: color 120ms ease;
  border-bottom: none;
}

.post-title a:hover {
  color: $brand-primary;
}

// Post meta
.post-meta {
  color: $brand-muted;
  font-size: 0.8rem;
}

.post-meta-item,
.post-meta-item a {
  color: $brand-muted;
  transition: color 120ms ease;
  border-bottom: none;
}

.post-meta-item a:hover {
  color: $brand-primary;
}

// Post excerpt
.post-body p {
  color: #475569;
  line-height: 1.65;
  font-size: 0.95rem;
}

// Read more
.post-button {
  margin-top: 10px;
}

.post-button a {
  color: $brand-primary;
  border: none;
  background: none;
  border-radius: 0;
  padding: 0;
  transition: color 120ms ease;
  font-size: 0.85rem;
  font-weight: 500;
  border-bottom: none;
}

.post-button a:hover {
  color: darken($brand-primary, 12%);
  background: none;
  border-color: transparent;
}

// ----------------------------------------------------------
// 7. Pagination
// ----------------------------------------------------------
.pagination {
  margin-top: 32px;
  border-top: 1px solid $brand-border;
  padding-top: 24px;
}

.pagination .page-number {
  border-radius: $brand-radius-sm;
  color: $brand-muted;
  transition: all 120ms ease;
  min-width: 34px;
  height: 34px;
  line-height: 34px;
  font-size: 0.85rem;
  border: 1px solid transparent;
}

.pagination .page-number.current {
  background: $brand-primary;
  color: #ffffff;
  border-color: $brand-primary;
}

.pagination .page-number:hover:not(.current) {
  background: $brand-primary-light;
  color: $brand-primary;
  border-color: $brand-primary-soft;
}

// ----------------------------------------------------------
// 8. Post detail
// ----------------------------------------------------------
.post-body {
  line-height: 1.8;
  color: $brand-text;
  font-size: 0.975rem;
}

.post-body h2 {
  font-size: 1.35rem;
  font-weight: 700;
  color: $brand-text;
  border-bottom: 1px solid $brand-border;
  padding-bottom: 6px;
  margin-top: 40px;
  margin-bottom: 14px;
}

.post-body h3 {
  font-size: 1.12rem;
  font-weight: 600;
  color: $brand-text;
  margin-top: 28px;
  margin-bottom: 10px;
}

// Links
.post-body a {
  color: $brand-primary;
  transition: color 120ms ease;
  text-decoration: none;
  border-bottom: 1px solid $brand-primary-soft;
}

.post-body a:hover {
  color: darken($brand-primary, 12%);
  border-bottom-color: $brand-primary;
}

// Inline code
.post-body code {
  background: $brand-code-bg;
  color: #1e40af;
  border-radius: 3px;
  padding: 1.5px 5px;
  font-size: 0.88em;
  border: none;
  font-family: "SF Mono", "Fira Code", "Fira Mono", "Roboto Mono", Menlo, Consolas, monospace;
}

// Code blocks
.post-body pre,
figure.highlight,
.highlight {
  background: #0f172a;
  border-radius: $brand-radius;
  border: none;
  font-family: "SF Mono", "Fira Code", "Fira Mono", "Roboto Mono", Menlo, Consolas, monospace;
  font-size: 0.85rem;
  line-height: 1.65;
}

figure.highlight figcaption,
.highlight .gutter {
  color: #64748b;
}

// Blockquote
.post-body blockquote {
  border-left: 3px solid $brand-primary;
  background: $brand-primary-light;
  color: #334155;
  padding: 12px 20px;
  margin: 20px 0;
  border-radius: 0 $brand-radius-sm $brand-radius-sm 0;
}

// Tables
.post-body table {
  border-collapse: collapse;
  width: 100%;
  margin: 20px 0;
  font-size: 0.875rem;
}

.post-body th {
  background: $brand-primary-light;
  color: $brand-text;
  font-weight: 600;
  padding: 8px 12px;
  border: 1px solid $brand-border;
  text-align: left;
  font-size: 0.85rem;
}

.post-body td {
  padding: 8px 12px;
  border: 1px solid $brand-border;
  font-size: 0.85rem;
}

.post-body tr:nth-child(even) td {
  background: #f8fafc;
}

// Images
.post-body img {
  border-radius: $brand-radius-sm;
  border: 1px solid $brand-border;
  max-width: 100%;
  box-shadow: none;
}

// ----------------------------------------------------------
// 9. TOC — clean docs-style
// ----------------------------------------------------------
.post-toc .nav .nav-item .nav-link {
  color: #64748b;
  transition: all 120ms ease;
  border-radius: $brand-radius-sm;
  padding: 3px 8px;
  font-size: 0.85rem;
  border-left: 2px solid transparent;
}

.post-toc .nav .nav-item .nav-link:hover {
  color: $brand-primary;
  background: transparent;
}

.post-toc .nav .active .nav-link {
  color: $brand-primary;
  background: $brand-primary-light;
  font-weight: 500;
  border-left-color: $brand-primary;
}

.post-toc .nav .nav-number {
  color: $brand-muted;
}

// ----------------------------------------------------------
// 10. Footer
// ----------------------------------------------------------
.footer {
  color: $brand-muted;
  font-size: 0.8rem;
  border-top: 1px solid $brand-border;
  padding-top: 24px;
  margin-top: 48px;
}

.footer a {
  color: $brand-muted;
  transition: color 120ms ease;
  border-bottom: none;
}

.footer a:hover {
  color: $brand-primary;
}

// ----------------------------------------------------------
// 11. Tags & Categories
// ----------------------------------------------------------
.tag-cloud a {
  color: #475569;
  border-radius: $brand-radius-sm;
  transition: all 120ms ease;
  padding: 3px 8px;
  font-size: 0.85rem;
}

.tag-cloud a:hover {
  color: $brand-primary;
  background: $brand-primary-light;
  border-color: $brand-primary-soft;
}

.category-list a {
  color: $brand-text;
  transition: color 120ms ease;
  border-bottom: none;
  font-size: 0.95rem;
}

.category-list a:hover {
  color: $brand-primary;
}

.category-list-count {
  color: $brand-muted;
}

// ----------------------------------------------------------
// 12. Archive
// ----------------------------------------------------------
.posts-collapse .post-header a {
  color: $brand-text;
  transition: color 120ms ease;
  border-bottom: none;
}

.posts-collapse .post-header a:hover {
  color: $brand-primary;
}

// ----------------------------------------------------------
// 13. Search
// ----------------------------------------------------------
.local-search-popup .search-result-list li {
  border-radius: $brand-radius-sm;
  transition: background 120ms ease;
}

.local-search-popup .search-result-list li:hover {
  background: $brand-primary-light;
}

.local-search-popup .search-keyword {
  color: $brand-primary;
  background: $brand-primary-soft;
  border-radius: 3px;
}

// ----------------------------------------------------------
// 14. Back to top
// ----------------------------------------------------------
.back-to-top {
  background: $brand-primary;
  color: #ffffff;
  border-radius: 50%;
  box-shadow: 0 2px 6px rgba($brand-primary, 0.25);
  transition: all 150ms ease;
}

.back-to-top:hover {
  background: darken($brand-primary, 8%);
  transform: translateY(-2px);
}

// ----------------------------------------------------------
// 15. Content width
// ----------------------------------------------------------
.content-wrap {
  width: 73%;
}

.main-inner {
  max-width: 860px;
}

// ----------------------------------------------------------
// 16. Post header
// ----------------------------------------------------------
.post-header h1 {
  font-size: 1.6rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.3;
}

// ----------------------------------------------------------
// 17. Misc
// ----------------------------------------------------------
.post-meta-divider {
  color: $brand-border;
}

// ----------------------------------------------------------
// 18. Scrollbar
// ----------------------------------------------------------
::-webkit-scrollbar {
  width: 6px;
}
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 3px;
}
::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

// ----------------------------------------------------------
// 19. Responsive
// ----------------------------------------------------------
@media (max-width: 768px) {
  .content-wrap { width: 100%; }
  .post-block { padding: 20px 0; }
}
