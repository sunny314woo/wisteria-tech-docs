/* ================================================================
   Wisteria Blog — AI workflow editorial theme
   NexT Pisces theme override
   ================================================================ */

// ----------------------------------------------------------
// Colors — calm docs palette with light/dark variants
// ----------------------------------------------------------
:root {
  --wt-topbar-height: 64px;
  --wt-primary: #2563eb;
  --wt-primary-hover: #1d4ed8;
  --wt-accent: #7c3aed;
  --wt-accent-soft: rgba(124, 58, 237, 0.12);
  --wt-primary-soft: rgba(37, 99, 235, 0.14);
  --wt-primary-light: rgba(37, 99, 235, 0.08);
  --wt-primary-shadow: rgba(37, 99, 235, 0.18);
  --wt-text: #0f172a;
  --wt-body-text: #334155;
  --wt-muted: #64748b;
  --wt-menu-text: #475569;
  --wt-border: #dbe3ee;
  --wt-bg: #ffffff;
  --wt-surface: #ffffff;
  --wt-sidebar-bg: #f8fafc;
  --wt-sidebar-panel: #ffffff;
  --wt-page-bg: #f4f7fb;
  --wt-code-bg: #eff6ff;
  --wt-code-text: #1e40af;
  --wt-code-block-bg: #0f172a;
  --wt-code-caption: #64748b;
  --wt-table-alt-bg: #f8fafc;
  --wt-scrollbar: #cbd5e1;
  --wt-scrollbar-hover: #94a3b8;
  --wt-brand-panel: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
  --wt-brand-border: #dbe3ee;
  --wt-brand-title: #0f172a;
  --wt-brand-muted: #64748b;
  --wt-brand-mark: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  --wt-brand-shadow: rgba(15, 23, 42, 0.08);
  --theme-color: var(--wt-primary);
  --brand-color: var(--wt-primary);
  --brand-hover-color: var(--wt-primary-hover);
}

@media (prefers-color-scheme: dark) {
  :root {
    --wt-primary: #93c5fd;
    --wt-primary-hover: #bfdbfe;
    --wt-accent: #c4b5fd;
    --wt-accent-soft: rgba(196, 181, 253, 0.12);
    --wt-primary-soft: rgba(147, 197, 253, 0.18);
    --wt-primary-light: rgba(147, 197, 253, 0.10);
    --wt-primary-shadow: rgba(96, 165, 250, 0.24);
    --wt-text: #f1f5f9;
    --wt-body-text: #cbd5e1;
    --wt-muted: #94a3b8;
    --wt-menu-text: #cbd5e1;
    --wt-border: #23314a;
    --wt-bg: #0f172a;
    --wt-surface: #111827;
    --wt-sidebar-bg: #0b1120;
    --wt-sidebar-panel: #101827;
    --wt-page-bg: #0b1120;
    --wt-code-bg: rgba(96, 165, 250, 0.16);
    --wt-code-text: #bfdbfe;
    --wt-code-block-bg: #020617;
    --wt-code-caption: #94a3b8;
    --wt-table-alt-bg: rgba(148, 163, 184, 0.08);
    --wt-scrollbar: #334155;
    --wt-scrollbar-hover: #475569;
    --wt-brand-panel: linear-gradient(180deg, #111827 0%, #0f172a 100%);
    --wt-brand-border: #23314a;
    --wt-brand-title: #f8fafc;
    --wt-brand-muted: #94a3b8;
    --wt-brand-mark: linear-gradient(135deg, #60a5fa 0%, #a78bfa 100%);
    --wt-brand-shadow: rgba(0, 0, 0, 0.22);
    color-scheme: dark;
  }
}

html[data-theme="light"] {
  --wt-topbar-height: 64px;
  --wt-primary: #2563eb;
  --wt-primary-hover: #1d4ed8;
  --wt-accent: #7c3aed;
  --wt-accent-soft: rgba(124, 58, 237, 0.12);
  --wt-primary-soft: rgba(37, 99, 235, 0.14);
  --wt-primary-light: rgba(37, 99, 235, 0.08);
  --wt-primary-shadow: rgba(37, 99, 235, 0.18);
  --wt-text: #0f172a;
  --wt-body-text: #334155;
  --wt-muted: #64748b;
  --wt-menu-text: #475569;
  --wt-border: #dbe3ee;
  --wt-bg: #ffffff;
  --wt-surface: #ffffff;
  --wt-sidebar-bg: #f8fafc;
  --wt-sidebar-panel: #ffffff;
  --wt-page-bg: #f4f7fb;
  --wt-code-bg: #eff6ff;
  --wt-code-text: #1e40af;
  --wt-code-block-bg: #0f172a;
  --wt-code-caption: #64748b;
  --wt-table-alt-bg: #f8fafc;
  --wt-scrollbar: #cbd5e1;
  --wt-scrollbar-hover: #94a3b8;
  --wt-brand-panel: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
  --wt-brand-border: #dbe3ee;
  --wt-brand-title: #0f172a;
  --wt-brand-muted: #64748b;
  --wt-brand-mark: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  --wt-brand-shadow: rgba(15, 23, 42, 0.08);
  color-scheme: light;
}

html[data-theme="dark"] {
  --wt-topbar-height: 64px;
  --wt-primary: #93c5fd;
  --wt-primary-hover: #bfdbfe;
  --wt-accent: #c4b5fd;
  --wt-accent-soft: rgba(196, 181, 253, 0.12);
  --wt-primary-soft: rgba(147, 197, 253, 0.18);
  --wt-primary-light: rgba(147, 197, 253, 0.10);
  --wt-primary-shadow: rgba(96, 165, 250, 0.24);
  --wt-text: #f1f5f9;
  --wt-body-text: #cbd5e1;
  --wt-muted: #94a3b8;
  --wt-menu-text: #cbd5e1;
  --wt-border: #23314a;
  --wt-bg: #0f172a;
  --wt-surface: #111827;
  --wt-sidebar-bg: #0b1120;
  --wt-sidebar-panel: #101827;
  --wt-page-bg: #0b1120;
  --wt-code-bg: rgba(96, 165, 250, 0.16);
  --wt-code-text: #bfdbfe;
  --wt-code-block-bg: #020617;
  --wt-code-caption: #94a3b8;
  --wt-table-alt-bg: rgba(148, 163, 184, 0.08);
  --wt-scrollbar: #334155;
  --wt-scrollbar-hover: #475569;
  --wt-brand-panel: linear-gradient(180deg, #111827 0%, #0f172a 100%);
  --wt-brand-border: #23314a;
  --wt-brand-title: #f8fafc;
  --wt-brand-muted: #94a3b8;
  --wt-brand-mark: linear-gradient(135deg, #60a5fa 0%, #a78bfa 100%);
  --wt-brand-shadow: rgba(0, 0, 0, 0.22);
  color-scheme: dark;
}

$brand-primary        = var(--wt-primary)
$brand-primary-hover  = var(--wt-primary-hover)
$brand-primary-soft   = var(--wt-primary-soft)
$brand-primary-light  = var(--wt-primary-light)
$brand-primary-shadow = var(--wt-primary-shadow)
$brand-text           = var(--wt-text)
$brand-body-text      = var(--wt-body-text)
$brand-muted          = var(--wt-muted)
$brand-menu-text      = var(--wt-menu-text)
$brand-border         = var(--wt-border)
$brand-bg             = var(--wt-bg)
$brand-surface        = var(--wt-surface)
$brand-sidebar-bg     = var(--wt-sidebar-bg)
$brand-sidebar-panel  = var(--wt-sidebar-panel)
$brand-page-bg        = var(--wt-page-bg)
$brand-code-bg        = var(--wt-code-bg)
$brand-code-text      = var(--wt-code-text)
$brand-code-block-bg  = var(--wt-code-block-bg)
$brand-code-caption   = var(--wt-code-caption)
$brand-table-alt-bg   = var(--wt-table-alt-bg)
$brand-scrollbar      = var(--wt-scrollbar)
$brand-scrollbar-hover = var(--wt-scrollbar-hover)
$brand-logo-bg        = var(--wt-brand-panel)
$brand-logo-border    = var(--wt-brand-border)
$brand-logo-title     = var(--wt-brand-title)
$brand-logo-mark      = var(--wt-brand-mark)
$brand-logo-muted     = var(--wt-brand-muted)
$brand-logo-shadow    = var(--wt-brand-shadow)
$brand-radius         = 6px
$brand-radius-sm      = 4px

// ----------------------------------------------------------
// 1. Global
// ----------------------------------------------------------
body {
  background: $brand-page-bg;
  color: $brand-text;
  font-family: -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.main,
.main-inner,
.content-wrap,
.content {
  background: $brand-page-bg;
}

// ----------------------------------------------------------
// 2. Site branding — integrated product-blog brand
// ----------------------------------------------------------
.site-brand-container,
.column .site-brand-container {
  background: $brand-logo-bg !important;
  border-bottom: 1px solid $brand-logo-border;
  box-shadow: inset 0 -1px 0 rgba(255, 255, 255, 0.35);
  padding: 22px 18px 18px;
}

.site-meta {
  padding: 0;
}

.brand {
  align-items: center;
  color: $brand-logo-title !important;
  display: inline-flex;
  gap: 10px;
  line-height: 1.2;
  max-width: 204px;
}

.brand:hover {
  color: $brand-primary !important;
}

.brand .logo-line {
  display: none;
}

.brand::before {
  align-items: center;
  background: transparent url("/images/wisteria-mark.svg") center / contain no-repeat;
  content: "";
  display: inline-flex;
  flex: 0 0 42px;
  height: 34px;
  justify-content: center;
  width: 42px;
}

.site-title {
  color: $brand-logo-title;
  font-weight: 700;
  font-size: 1.03rem;
  letter-spacing: 0;
  line-height: 1.25;
}

.brand .site-title,
.brand:hover .site-title {
  color: inherit;
}

.site-subtitle {
  color: $brand-logo-muted;
  margin: 9px auto 0;
  max-width: 205px;
  font-size: 0.74rem;
  font-weight: 400;
  line-height: 1.55;
}

.site-tools {
  align-items: center;
  display: flex;
  gap: 8px;
  position: fixed;
  right: 18px;
  top: 14px;
  z-index: 20;
}

.site-tools-link,
.site-tools-button,
.ui-language-switch {
  backdrop-filter: blur(14px);
  background: $brand-sidebar-panel;
  border: 1px solid $brand-border;
  box-shadow: 0 10px 26px rgba(15, 23, 42, 0.08);
}

.site-tools-link,
.site-tools-button {
  align-items: center;
  border-radius: 999px;
  color: $brand-muted;
  display: inline-flex;
  font-size: 0.76rem;
  font-weight: 700;
  gap: 6px;
  height: 32px;
  justify-content: center;
  letter-spacing: 0;
  line-height: 1;
  padding: 0 12px;
  text-decoration: none;
}

.site-tools-link:hover,
.site-tools-button:hover {
  color: $brand-primary;
}

.site-tools-button {
  cursor: pointer;
}

.site-tools-theme-icon {
  font-size: 0.86rem;
}

.ui-language-switch {
  border-radius: 999px;
  display: flex;
  gap: 3px;
  justify-content: center;
  padding: 3px;
}

.ui-language-switch-button {
  appearance: none;
  background: transparent;
  border: 1px solid $brand-border;
  border-radius: 999px;
  color: $brand-muted;
  cursor: pointer;
  font-size: 0.72rem;
  font-weight: 700;
  height: 24px;
  letter-spacing: 0;
  line-height: 1;
  min-width: 36px;
  padding: 0 9px;
  transition: background 150ms ease, border-color 150ms ease, color 150ms ease;
}

.ui-language-switch-button:hover,
.ui-language-switch-button.is-active {
  background: $brand-primary-light;
  border-color: $brand-primary-soft;
  color: $brand-primary;
}

.ui-language-switch-button.is-active {
  box-shadow: inset 0 0 0 1px $brand-primary-soft;
}

html[data-theme="dark"] .site-tools-button .site-tools-theme-icon::before {
  content: "●";
}

html[data-theme="light"] .site-tools-button .site-tools-theme-icon::before {
  content: "○";
}

html[data-theme] .site-tools-theme-icon {
  font-size: 0;
}

html[data-theme] .site-tools-theme-icon::before {
  font-size: 0.78rem;
}

// ----------------------------------------------------------
// 3. Menu — compact knowledge-base navigation
// ----------------------------------------------------------
.site-nav {
  background: $brand-sidebar-panel;
  border-top: 1px solid $brand-border;
  padding: 14px 12px 0;
  margin-top: 10px;
}

.site-nav .main-menu {
  background: transparent;
  margin: 0;
  padding: 0 0 14px;
}

.site-nav .menu-item {
  margin: 1px 0;
}

.site-nav .menu-item a {
  color: $brand-menu-text;
  font-weight: 500;
  font-size: 0.875rem;
  padding: 8px 12px;
  border-radius: 8px;
  transition: all 150ms ease;
  display: flex;
  align-items: center;
  gap: 8px;
}

.site-nav .menu-item a:hover {
  color: $brand-primary;
  background: $brand-primary-light;
}

.site-nav .menu-item-active a {
  color: $brand-primary;
  background: linear-gradient(90deg, $brand-primary-light, transparent);
  border-left: none;
  font-weight: 600;
}

.menu-item .badge {
  background: $brand-primary-soft;
  color: $brand-primary;
  font-weight: 500;
}

// ----------------------------------------------------------
// 4. Sidebar — flat, clean, no shadows
// ----------------------------------------------------------
.sidebar-inner {
  background: $brand-sidebar-bg;
  border-radius: 0;
  box-shadow: none;
  border: none;
  border-right: 1px solid $brand-border;
  padding: 0;
  overflow: visible;
}

.sidebar {
  background: transparent;
}

// ----------------------------------------------------------
// 5. Sidebar panels — docs-nav style
// ----------------------------------------------------------
.sidebar-panel {
  padding: 0 20px 22px 20px;
}

.site-overview-wrap {
  background: $brand-sidebar-panel;
}

.links-of-blogroll {
  margin-top: 20px;
  padding-top: 16px;
  border-top: 1px solid $brand-border;
}

.links-of-blogroll-title {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: $brand-muted;
  margin: 0 0 8px 0;
  padding: 0;
  text-align: left;
}

.links-of-blogroll-list {
  list-style: none;
  margin: 0;
  padding: 0;
}

.links-of-blogroll-item {
  margin: 0;
  padding: 0;
}

.links-of-blogroll-item a {
  display: block;
  color: $brand-menu-text;
  font-size: 0.825rem;
  padding: 4px 8px;
  border-radius: $brand-radius-sm;
  transition: all 120ms ease;
  line-height: 1.4;
  white-space: normal;
  overflow: visible;
  border-left: 2px solid transparent;
  border-bottom: 0 !important;
  text-align: left;
}

.links-of-blogroll-item a:hover {
  color: $brand-primary;
  background: $brand-primary-light;
  border-left-color: $brand-primary;
}

.sidebar-inner > .wt-related-posts {
  border-top: 1px solid $brand-border;
  margin: 16px 20px 0;
  padding-top: 14px;
}

.wt-related-posts .links-of-blogroll-title {
  margin-bottom: 8px;
}

.wt-related-posts .links-of-blogroll-item a {
  font-size: 0.8rem;
  line-height: 1.45;
  padding: 5px 8px;
}

// Sidebar state (posts/categories/tags count)
.site-state {
  padding: 4px 0;
}

.site-state-item {
  padding: 0 8px;
}

.site-state-item a {
  color: $brand-menu-text;
  font-size: 0.8rem;
  border-bottom: none;
}

.site-state-item a:hover {
  color: $brand-primary;
}

.site-state-item-count {
  font-weight: 700;
  font-size: 1rem;
  color: $brand-text;
}

// ----------------------------------------------------------
// 6. Post list — clean, no card, subtle separators
// ----------------------------------------------------------
.post-block {
  background: transparent;
  border-radius: 0;
  box-shadow: none;
  border: none;
  border-bottom: 1px solid $brand-border;
  margin-bottom: 0;
  padding: 28px 0;
  transition: none;
  text-align: left;
}

.post-block:hover {
  transform: none;
  box-shadow: none;
}

.post-block:first-child {
  padding-top: 8px;
}

.post-block + .post-block {
  margin-top: 0;
}

// Post titles
.post-title {
  font-size: 1.2rem;
  font-weight: 600;
  line-height: 1.4;
  letter-spacing: -0.01em;
  text-align: left;
  margin-bottom: 6px;
}

.post-title a {
  color: $brand-text;
  transition: color 120ms ease;
  border-bottom: none;
}

.posts-collapse .post-title-link {
  color: $brand-text !important;
  font-weight: 650;
}

.posts-collapse .post-title-link span {
  color: inherit;
}

.post-title a:hover {
  color: $brand-primary;
}

.posts-collapse .post-title-link:hover {
  color: $brand-primary !important;
}

html[data-theme="dark"] .posts-expand .post-title-link,
html[data-theme="dark"] .posts-collapse .post-header a,
html[data-theme="dark"] .post-title a {
  color: $brand-text !important;
}

html[data-theme="dark"] .posts-expand .post-title-link:hover,
html[data-theme="dark"] .posts-collapse .post-header a:hover,
html[data-theme="dark"] .post-title a:hover {
  color: $brand-primary-hover !important;
}

// Post meta
.post-meta {
  color: $brand-muted;
  font-size: 0.8rem;
}

.post-meta-item,
.post-meta-item a {
  color: $brand-muted;
  transition: color 120ms ease;
  border-bottom: none;
}

.post-meta-item a:hover {
  color: $brand-primary;
}

html[data-theme="dark"] .post-meta,
html[data-theme="dark"] .post-meta-item,
html[data-theme="dark"] .post-meta-item a,
html[data-theme="dark"] .post-meta time {
  color: $brand-muted !important;
}

html[data-theme="dark"] .post-meta-item a:hover {
  color: $brand-primary-hover !important;
}

// Post excerpt
.post-body p {
  color: $brand-body-text;
  line-height: 1.65;
  font-size: 0.95rem;
}

// Read more
.post-button {
  margin-top: 10px;
}

.post-button a {
  color: $brand-primary;
  border: none;
  background: none;
  border-radius: 0;
  padding: 0;
  transition: color 120ms ease;
  font-size: 0.85rem;
  font-weight: 500;
  border-bottom: none;
}

.post-button a:hover {
  color: $brand-primary-hover;
  background: none;
  border-color: transparent;
}

html[data-theme="dark"] .post-button a {
  color: $brand-primary !important;
}

html[data-theme="dark"] .post-button a:hover {
  color: $brand-primary-hover !important;
}

.post-footer .post-eof {
  display: none;
}

// ----------------------------------------------------------
// 7. Pagination
// ----------------------------------------------------------
.pagination {
  margin-top: 32px;
  border-top: 1px solid $brand-border;
  padding-top: 24px;
}

.pagination .page-number {
  border-radius: $brand-radius-sm;
  color: $brand-muted;
  transition: all 120ms ease;
  min-width: 34px;
  height: 34px;
  line-height: 34px;
  font-size: 0.85rem;
  border: 1px solid transparent;
}

.pagination .page-number.current {
  background: $brand-primary;
  color: #ffffff;
  border-color: $brand-primary;
}

.pagination .page-number:hover:not(.current) {
  background: $brand-primary-light;
  color: $brand-primary;
  border-color: $brand-primary-soft;
}

// ----------------------------------------------------------
// 8. Post detail
// ----------------------------------------------------------
.post-body {
  line-height: 1.8;
  color: $brand-text;
  font-size: 0.975rem;
}

.post-body h2 {
  font-size: 1.35rem;
  font-weight: 700;
  color: $brand-text;
  border-bottom: 1px solid $brand-border;
  padding-bottom: 6px;
  margin-top: 40px;
  margin-bottom: 14px;
}

.post-body h3 {
  font-size: 1.12rem;
  font-weight: 600;
  color: $brand-text;
  margin-top: 28px;
  margin-bottom: 10px;
}

// Links
.post-body a {
  color: $brand-primary;
  transition: color 120ms ease;
  text-decoration: none;
  border-bottom: 1px solid $brand-primary-soft;
}

.post-body a:hover {
  color: $brand-primary-hover;
  border-bottom-color: $brand-primary;
}

// Inline code
.post-body code {
  background: $brand-code-bg;
  color: $brand-code-text;
  border-radius: 3px;
  padding: 1.5px 5px;
  font-size: 0.88em;
  border: none;
  font-family: "SF Mono", "Fira Code", "Fira Mono", "Roboto Mono", Menlo, Consolas, monospace;
}

// Code blocks
.post-body pre,
figure.highlight,
.highlight {
  background: $brand-code-block-bg;
  border-radius: $brand-radius;
  border: none;
  font-family: "SF Mono", "Fira Code", "Fira Mono", "Roboto Mono", Menlo, Consolas, monospace;
  font-size: 0.85rem;
  line-height: 1.65;
}

figure.highlight figcaption,
.highlight .gutter {
  color: $brand-code-caption;
}

// Blockquote
.post-body blockquote {
  border-left: 3px solid $brand-primary;
  background: $brand-primary-light;
  color: $brand-body-text;
  padding: 12px 20px;
  margin: 20px 0;
  border-radius: 0 $brand-radius-sm $brand-radius-sm 0;
}

// Tables
.post-body table {
  border-collapse: collapse;
  width: 100%;
  margin: 20px 0;
  font-size: 0.875rem;
}

.post-body th {
  background: $brand-primary-light;
  color: $brand-text;
  font-weight: 600;
  padding: 8px 12px;
  border: 1px solid $brand-border;
  text-align: left;
  font-size: 0.85rem;
}

.post-body td {
  padding: 8px 12px;
  border: 1px solid $brand-border;
  font-size: 0.85rem;
}

.post-body tr:nth-child(even) td {
  background: $brand-table-alt-bg;
}

// Images
.post-body img {
  border-radius: $brand-radius-sm;
  border: 1px solid $brand-border;
  max-width: 100%;
  box-shadow: none;
}

// ----------------------------------------------------------
// 9. TOC — clean docs-style
// ----------------------------------------------------------
.post-toc .nav .nav-item .nav-link {
  color: $brand-muted;
  transition: all 120ms ease;
  border-radius: $brand-radius-sm;
  padding: 3px 8px;
  font-size: 0.85rem;
  border-left: 2px solid transparent;
}

.post-toc .nav .nav-item .nav-link:hover {
  color: $brand-primary;
  background: transparent;
}

.post-toc .nav .active .nav-link {
  color: $brand-primary;
  background: $brand-primary-light;
  font-weight: 500;
  border-left-color: $brand-primary;
}

.post-toc .nav .nav-number {
  color: $brand-muted;
}

// ----------------------------------------------------------
// 10. Footer
// ----------------------------------------------------------
.footer {
  color: $brand-muted;
  font-size: 0.8rem;
  border-top: 1px solid $brand-border;
  padding-top: 24px;
  margin-top: 48px;
}

.footer a {
  color: $brand-muted;
  transition: color 120ms ease;
  border-bottom: none;
}

.footer a:hover {
  color: $brand-primary;
}

// ----------------------------------------------------------
// 11. Tags & Categories
// ----------------------------------------------------------
.tag-cloud a {
  color: $brand-menu-text;
  border-radius: $brand-radius-sm;
  transition: all 120ms ease;
  padding: 3px 8px;
  font-size: 0.85rem;
}

.tag-cloud a:hover {
  color: $brand-primary;
  background: $brand-primary-light;
  border-color: $brand-primary-soft;
}

.category-list a {
  color: $brand-text;
  transition: color 120ms ease;
  border-bottom: none;
  font-size: 0.95rem;
}

.category-list a:hover {
  color: $brand-primary;
}

.category-list-count {
  color: $brand-muted;
}

// ----------------------------------------------------------
// 12. Archive
// ----------------------------------------------------------
.posts-collapse .post-header a {
  color: $brand-text;
  transition: color 120ms ease;
  border-bottom: none;
}

.posts-collapse .post-header a:hover {
  color: $brand-primary;
}

// ----------------------------------------------------------
// 13. Search
// ----------------------------------------------------------
.local-search-popup .search-result-list li {
  border-radius: $brand-radius-sm;
  transition: background 120ms ease;
}

.local-search-popup .search-result-list li:hover {
  background: $brand-primary-light;
}

.local-search-popup .search-keyword {
  color: $brand-primary;
  background: $brand-primary-soft;
  border-radius: 3px;
}

// ----------------------------------------------------------
// 14. Back to top
// ----------------------------------------------------------
.back-to-top {
  background: $brand-primary;
  color: #ffffff;
  border-radius: 50%;
  box-shadow: 0 2px 6px $brand-primary-shadow;
  transition: all 150ms ease;
}

.back-to-top:hover {
  background: $brand-primary-hover;
  transform: translateY(-2px);
}

// ----------------------------------------------------------
// 15. Content width
// ----------------------------------------------------------
.content-wrap {
  width: 73%;
}

.main-inner {
  max-width: 860px;
}

// ----------------------------------------------------------
// 16. Post header — override theme centering
// ----------------------------------------------------------
.main-inner .posts-expand .post-header {
  text-align: left;
}

.main-inner .post-meta {
  justify-content: flex-start;
}

.post-header h1 {
  font-size: 1.6rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.3;
}

// ----------------------------------------------------------
// 17. Misc
// ----------------------------------------------------------
.post-meta-divider {
  color: $brand-border;
}

// ----------------------------------------------------------
// 18. Scrollbar
// ----------------------------------------------------------
::-webkit-scrollbar {
  width: 6px;
}
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb {
  background: $brand-scrollbar;
  border-radius: 3px;
}
::-webkit-scrollbar-thumb:hover { background: $brand-scrollbar-hover; }

// ----------------------------------------------------------
// 19. Responsive
// ----------------------------------------------------------
@media (max-width: 768px) {
  .content-wrap { width: 100%; }
  .post-block { padding: 20px 0; }
  .site-brand-container,
  .column .site-brand-container {
    padding-bottom: 14px;
  }
  .site-tools {
    justify-content: center;
    margin: 12px auto 0;
    position: static;
  }
  .site-tools-link,
  .site-tools-button {
    height: 30px;
    padding: 0 10px;
  }
  .ui-language-switch-button {
    min-width: 32px;
    padding: 0 8px;
  }
}

// ----------------------------------------------------------
// 20. Tailwind-docs inspired fixed top bar
// ----------------------------------------------------------
.headband {
  display: none;
}

.header {
  background: transparent !important;
  border: 0 !important;
  box-shadow: none !important;
  padding: 0 !important;
}

.header > .site-brand-container,
.header > .site-nav {
  display: none !important;
}

.main {
  padding-top: calc(var(--wt-topbar-height) + 18px);
}

.wt-topbar {
  background: rgba(255, 255, 255, 0.86);
  border-bottom: 1px solid rgba(148, 163, 184, 0.26);
  box-shadow: 0 1px 0 rgba(255, 255, 255, 0.70), 0 18px 40px rgba(15, 23, 42, 0.06);
  backdrop-filter: saturate(180%) blur(18px);
  left: 0;
  min-height: var(--wt-topbar-height);
  position: fixed;
  right: 0;
  top: 0;
  z-index: 90;
}

.wt-topbar-inner {
  align-items: center;
  display: flex;
  gap: 22px;
  margin: 0 auto;
  max-width: 1240px;
  min-height: var(--wt-topbar-height);
  padding: 0 24px;
}

.wt-brand {
  align-items: center;
  border-bottom: 0;
  color: $brand-text;
  display: inline-flex;
  flex: 0 0 auto;
  gap: 10px;
  min-width: 190px;
  text-decoration: none;
}

.wt-brand:hover {
  color: $brand-primary;
}

.wt-brand-mark {
  background: transparent url("/images/wisteria-mark.svg") center / contain no-repeat;
  display: inline-flex;
  flex: 0 0 46px;
  height: 32px;
  width: 46px;
}

.wt-brand-copy {
  display: grid;
  gap: 1px;
  min-width: 0;
}

.wt-brand-name {
  color: $brand-text;
  font-size: 0.94rem;
  font-weight: 750;
  line-height: 1.1;
  white-space: nowrap;
}

.wt-brand-subtitle {
  color: $brand-muted;
  font-size: 0.71rem;
  font-weight: 500;
  line-height: 1.2;
  white-space: nowrap;
}

.wt-nav {
  align-items: center;
  display: flex;
  flex: 1 1 auto;
  gap: 2px;
  min-width: 0;
}

.wt-nav-link {
  border-bottom: 0;
  border-radius: 7px;
  color: $brand-menu-text;
  display: inline-flex;
  font-size: 0.84rem;
  font-weight: 650;
  line-height: 1;
  padding: 10px 11px;
  text-decoration: none;
  transition: background 140ms ease, color 140ms ease;
  white-space: nowrap;
}

.wt-nav-link:hover {
  background: $brand-primary-light;
  color: $brand-primary;
}

.wt-actions {
  align-items: center;
  background: rgba(248, 250, 252, 0.66);
  border: 1px solid rgba(148, 163, 184, 0.22);
  border-radius: 8px;
  display: flex;
  flex: 0 0 auto;
  gap: 0;
  margin-left: auto;
  padding: 2px;
}

.wt-search-trigger,
.wt-tool,
.wt-icon-link {
  align-items: center;
  background: transparent;
  border: 0;
  border-radius: 6px;
  color: $brand-muted;
  display: inline-flex;
  font-size: 0.78rem;
  font-weight: 700;
  gap: 6px;
  height: 32px;
  justify-content: center;
  line-height: 1;
  padding: 0 10px;
  text-decoration: none;
  transition: background 140ms ease, color 140ms ease;
  white-space: nowrap;
}

.wt-search-trigger,
.wt-tool {
  cursor: pointer;
}

.wt-search-trigger:hover,
.wt-tool:hover,
.wt-icon-link:hover {
  background: $brand-primary-light;
  color: $brand-primary;
}

.wt-search-trigger kbd {
  background: #fff;
  border: 1px solid rgba(148, 163, 184, 0.36);
  border-radius: 5px;
  color: $brand-muted;
  font-family: inherit;
  font-size: 0.66rem;
  font-weight: 750;
  line-height: 1;
  padding: 3px 5px;
}

.wt-github-link i {
  color: $brand-text;
  font-size: 1.06rem;
}

.wt-github-link:hover i {
  color: $brand-primary;
}

.wt-language-toggle {
  min-width: 34px;
}

.wt-theme-toggle {
  appearance: none;
  min-width: 34px;
  padding: 0;
}

.wt-theme-icon {
  align-items: center;
  display: inline-flex;
  height: 22px;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.wt-theme-icon-sun,
.wt-theme-icon-moon {
  display: none;
}

html[data-theme="light"] .wt-theme-icon-sun,
html[data-theme="dark"] .wt-theme-icon-moon {
  display: inline-flex;
}

.wt-theme-icon svg {
  fill: none;
  height: 15px;
  stroke: currentColor;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-width: 2;
  width: 15px;
}

.wt-theme-icon-moon svg {
  fill: currentColor;
  stroke: currentColor;
}

html[data-theme="light"] .wt-theme-icon-sun,
html[data-theme="dark"] .wt-theme-icon-moon {
  color: $brand-primary;
}

html[data-theme="dark"] .wt-topbar {
  background: rgba(7, 10, 22, 0.86);
  border-bottom-color: rgba(148, 163, 184, 0.14);
  box-shadow: 0 1px 0 rgba(255, 255, 255, 0.03), 0 18px 42px rgba(0, 0, 0, 0.30);
}

html[data-theme="dark"] .wt-actions {
  background: rgba(15, 23, 42, 0.58);
  border-color: rgba(148, 163, 184, 0.14);
}

html[data-theme="dark"] .wt-search-trigger,
html[data-theme="dark"] .wt-tool,
html[data-theme="dark"] .wt-icon-link {
  background: transparent;
}

html[data-theme="dark"] .wt-search-trigger:hover,
html[data-theme="dark"] .wt-tool:hover,
html[data-theme="dark"] .wt-icon-link:hover {
  background: rgba(196, 181, 253, 0.10);
}

html[data-theme="dark"] .wt-search-trigger kbd {
  background: #111827;
  border-color: rgba(148, 163, 184, 0.18);
}

html[data-theme="dark"] .column,
html[data-theme="dark"] .sidebar,
html[data-theme="dark"] .sidebar-inner,
html[data-theme="dark"] .site-overview-wrap {
  background: $brand-sidebar-bg !important;
}

html[data-theme="dark"] .sidebar-inner {
  border-right-color: transparent;
  box-shadow: none !important;
}

.sidebar {
  top: calc(var(--wt-topbar-height) + 14px) !important;
}

.sidebar-inner {
  max-height: calc(100vh - var(--wt-topbar-height) - 28px) !important;
  border-right-color: transparent;
}

.sidebar-toggle {
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(148, 163, 184, 0.28);
  border-radius: 6px;
  box-shadow: 0 8px 24px rgba(15, 23, 42, 0.12);
  color: $brand-text;
}

.sidebar-toggle .toggle-line {
  background: $brand-text;
}

.sidebar-toggle:hover,
.sidebar-active .sidebar-toggle {
  background: $brand-primary-light;
}

.sidebar-toggle:hover .toggle-line,
.sidebar-active .sidebar-toggle .toggle-line {
  background: $brand-primary;
}

html[data-theme="dark"] .sidebar-toggle {
  background: rgba(15, 23, 42, 0.92);
  border-color: rgba(148, 163, 184, 0.18);
  box-shadow: 0 8px 28px rgba(0, 0, 0, 0.28);
}

html[data-theme="dark"] .sidebar-toggle .toggle-line {
  background: $brand-body-text;
}

.search-pop-overlay {
  z-index: 120;
}

.search-popup {
  border: 1px solid $brand-border;
  border-radius: 8px;
  box-shadow: 0 30px 80px rgba(15, 23, 42, 0.22);
  height: min(44vh, 420px);
  max-height: 440px;
  overflow: hidden;
  width: unquote('min(700px, calc(100vw - 32px))');
}

.search-popup .search-header {
  background: $brand-surface;
  border-bottom: 1px solid $brand-border;
}

.search-popup .search-input {
  color: $brand-text;
}

.search-popup .search-result-container {
  height: calc(100% - 46px);
  min-height: 220px;
  overflow: auto;
}

.search-popup .search-result-icon:has(.fa-spinner),
.search-popup .search-result-icon:has(.fa-search) {
  display: none;
}

html[data-theme="dark"] .search-popup {
  background: $brand-surface;
  box-shadow: 0 30px 90px rgba(0, 0, 0, 0.46);
}

@media (max-width: 1060px) {
  .wt-topbar-inner {
    gap: 12px;
    padding: 0 14px;
  }

  .wt-nav {
    overflow-x: auto;
    scrollbar-width: none;
  }

  .wt-nav::-webkit-scrollbar {
    display: none;
  }

  .wt-search-trigger kbd,
  .wt-icon-link span {
    display: none;
  }

  .wt-icon-link {
    padding: 0;
    width: 36px;
  }
}

@media (max-width: 768px) {
  :root,
  html[data-theme="light"],
  html[data-theme="dark"] {
    --wt-topbar-height: 150px;
  }

  .main {
    padding-top: calc(var(--wt-topbar-height) + 14px);
  }

  .wt-topbar-inner {
    align-content: center;
    display: grid;
    gap: 8px 10px;
    grid-template-columns: minmax(0, 1fr);
    padding: 8px 12px;
  }

  .wt-brand {
    min-width: 0;
  }

  .wt-brand-subtitle {
    display: none;
  }

  .wt-nav {
    grid-column: 1 / -1;
    order: 3;
    padding-bottom: 2px;
  }

  .wt-nav-link {
    padding: 9px 10px;
  }

  .wt-actions {
    grid-column: 1 / -1;
    justify-self: start;
    margin-left: 0;
    min-width: 0;
    order: 2;
  }

  .wt-search-trigger {
    padding: 0 9px;
  }

  .wt-search-trigger span {
    display: none;
  }

  .wt-tool,
  .wt-icon-link {
    padding: 0 9px;
  }
}
